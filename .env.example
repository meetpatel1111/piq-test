# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Jira Configuration
JIRA_URL=https://your-org.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_TOKEN=your-jira-api-token
JIRA_PROJECT=DEVOPS
JIRA_ASSIGNEE=your-jira-user-id

# AI Configuration
AI_API_KEY=your-openai-api-key
AI_PROVIDER=openai
AI_MODEL=gpt-4

# Optional: Gemini API Key (if using Gemini instead of OpenAI)
GEMINI_API_KEY=your-gemini-api-key

# Optional: Notification Webhooks
SLACK_WEBHOOK=your-slack-webhook-url
TEAMS_WEBHOOK=your-teams-webhook-url

# Application Configuration
NODE_ENV=development
PORT=3000

# Database Configuration (if needed)
DATABASE_URL=mongodb://localhost:27017/piq-test

# External Services
EXTERNAL_API_URL=https://jsonplaceholder.typicode.com
