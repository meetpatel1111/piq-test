{
  "project": {
    "name": "piq-test",
    "owner": "Meetkumar Patel",
    "version": "1.0.0"
  },
  "jira": {
    "project": "SCRUM",
    "issueType": "Bug",
    "priority": "Medium",
    "labels": ["pipelineiq", "automated-failure"]
  },
  "ai": {
    "provider": "gemini",
    "model": "gemini-2.5-flash-lite",
    "mode": "assist",
    "enrichment": {
      "rca": true,
      "remediation": true,
      "severity": true
    }
  },
  "analysis": {
    "logAggregation": true,
    "maxLogLines": 1000,
    "deduplication": true,
    "deduplicationWindow": 24
  },
  "environments": {
    "testing": {
      "severityMapping": {
        "Critical": "High",
        "Error": "Medium",
        "Warning": "Low"
      }
    }
  }
}
