{
  "jira": {
    "type": "cloud",
    "baseUrl": "${JIRA_URL}",
    "email": "${JIRA_EMAIL}",
    "apiToken": "${JIRA_TOKEN}",
    "strictGDPR": true
  },
  "jiraProject": "SCRUM",
  "issueType": "Bug",
  "defaultLabels": ["ci-cd", "pipeline-failure", "automated"],
  "ai": {
    "mode": "assist",
    "provider": "gemini",
    "apiKey": "${AI_API_KEY}",
    "model": "gemini-2.5-flash"
  },
  "dedup": {
    "enabled": true,
    "windowHours": 24
  },
  "maskSecrets": true,
  "severity": {
    "critical": ["security", "production-down"],
    "high": ["database", "api-failure"],
    "medium": ["test-failure", "build-error"],
    "low": ["linting", "warning"]
  },
  "customFields": {
    "repository": "customfield_10010",
    "branch": "customfield_10011",
    "commit": "customfield_10012",
    "pipeline": "customfield_10013",
    "environment": "customfield_10014"
  },
  "notifications": {
    "slack": {
      "enabled": false,
      "webhook": "${SLACK_WEBHOOK}"
    },
    "teams": {
      "enabled": false,
      "webhook": "${TEAMS_WEBHOOK}"
    }
  }
}
